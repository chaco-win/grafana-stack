{
  "title": "OPNsense Router",
  "uid": "opnsense",
  "tags": ["opnsense", "network", "router"],
  "timezone": "America/Chicago",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "interface",
        "label": "Interface",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(net_bytes_recv{host=\"opnsense\"}, interface)",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - cpu_usage_idle{host=\"opnsense\", cpu=\"cpu-total\"}",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "mem_used_percent{host=\"opnsense\"}",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 3,
      "title": "System Uptime",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "system_uptime{host=\"opnsense\"}",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "title": "Active Processes",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "processes_running{host=\"opnsense\"}",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "title": "CPU Cores",
      "type": "stat",
      "gridPos": { "x": 16, "y": 3, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(cpu_usage_idle{host=\"opnsense\", cpu!=\"cpu-total\"})",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "title": "Total Memory",
      "type": "stat",
      "gridPos": { "x": 20, "y": 3, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "mem_total{host=\"opnsense\"}",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 7,
      "title": "Network Inbound Traffic",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(net_bytes_recv{host=\"opnsense\", interface=~\"$interface\"}[5m]) * 8",
          "legendFormat": "{{interface}} in",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 8,
      "title": "Network Outbound Traffic",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(net_bytes_sent{host=\"opnsense\", interface=~\"$interface\"}[5m]) * 8",
          "legendFormat": "{{interface}} out",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 9,
      "title": "Network Packets In",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(net_packets_recv{host=\"opnsense\", interface=~\"$interface\"}[5m])",
          "legendFormat": "{{interface}} packets/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 10,
      "title": "Network Errors & Drops",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(net_err_in{host=\"opnsense\", interface=~\"$interface\"}[5m])",
          "legendFormat": "{{interface}} err in",
          "refId": "A"
        },
        {
          "expr": "rate(net_err_out{host=\"opnsense\", interface=~\"$interface\"}[5m])",
          "legendFormat": "{{interface}} err out",
          "refId": "B"
        },
        {
          "expr": "rate(net_drop_in{host=\"opnsense\", interface=~\"$interface\"}[5m])",
          "legendFormat": "{{interface}} drop in",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 11,
      "title": "Disk Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "disk_used_percent{host=\"opnsense\"}",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 12,
      "title": "Disk IO",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(diskio_read_bytes{host=\"opnsense\"}[5m])",
          "legendFormat": "{{name}} read",
          "refId": "A"
        },
        {
          "expr": "rate(diskio_write_bytes{host=\"opnsense\"}[5m])",
          "legendFormat": "{{name}} write",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      }
    }
  ]
}
